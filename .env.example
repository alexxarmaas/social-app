# Base de datos Prisma / NextAuth
DATABASE_URL="postgresql://usuario:password@localhost:5432/tramassso"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera_un_valor_seguro_con_openssl_rand_base64_32"

# Superadmin inicial en la base de datos de DATABASE_URL
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD=""

# Supabase: contenido editable de eventos, rutas y colaboradores
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu_clave_anon_publica"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key_solo_servidor"

# Notificaciones del formulario mediante el correo de Nominalia
SMTP_HOST="authsmtp.securemail.pro"
SMTP_PORT="465"
SMTP_USER="contacto@tramassso.com"
SMTP_PASSWORD="contrasena_del_buzon_solo_en_el_servidor"
CONTACT_TO_EMAIL="contacto@tramassso.com"

# Cloudinary: subida firmada desde el panel admin
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Google AdSense, opcional
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-2456720977453256"
NEXT_PUBLIC_ADSENSE_SLOT_EVENTS_1="0000000000"
NEXT_PUBLIC_ADSENSE_SLOT_ROUTES_1="0000000000"

# Analiticas agregadas del footer, opcionales
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""

# Vercel Blob, opcional si lo necesitas más adelante
BLOB_READ_WRITE_TOKEN=""
